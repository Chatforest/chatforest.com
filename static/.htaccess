RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve markdown files with UTF-8 charset to prevent mojibake
AddCharset utf-8 .md

# Redirect old Cerebras review slug to updated review (Run 1069 refresh)
RewriteRule ^reviews/cerebras-wafer-scale-llm-inference/(.*)$ /reviews/cerebras-wse-wafer-scale-inference/$1 [R=301,L]
